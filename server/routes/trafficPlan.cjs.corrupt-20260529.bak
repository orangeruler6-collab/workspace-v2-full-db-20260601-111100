const fs = require('fs');
const os = require('os');
const path = require('path');
const { spawn } = require('child_process');
const createLogger = require('../lib/logger.cjs');
const createSqliteAdapter = require('../lib/sqlite.cjs');

const logger = createLogger('routes:trafficPlan');

const EMPTY_STATE = {
  plans: [],
  importedVideos: [],
  accountLibrary: [],
  applyRequests: []
};

function nowSec() {
  return Math.floor(Date.now() / 1000);
}

function parseJson(value, fallback) {
  if (!value) return fallback;
  try {
    return JSON.parse(value);
  } catch (e) {
    return fallback;
  }
}

function jsonValue(value) {
  return JSON.stringify(value === undefined ? null : value);
}

function text(value) {
  return String(value || '').trim();
}

function normalizedText(value) {
  return text(value).replace(/\s+/g, '').toLowerCase();
}

function num(value) {
  if (typeof value === 'string') {
    const raw = value.trim().replace(/,/g, '');
    const matched = raw.match(/([\\d.]+)\\s*([w��kǧ]?)/i);
    if (matched) {
      const base = Number(matched[1]);
      if (Number.isFinite(base)) {
        const unit = matched[2].toLowerCase();
        if (unit === 'w' || unit === '��') return Math.round(base * 10000);
        if (unit === 'k' || unit === 'ǧ') return Math.round(base * 1000);
        return base;
      }
    }
  }
  const n = Number(value);
  return Number.isFinite(n) ? n : 0;
}

function cleanCell(value) {
  return text(value).replace(/^\uFEFF/, '').replace(/\t/g, '').trim();
}

function parseCsv(textValue) {
  const rows = [];
  let row = [];
  let cell = '';
  let quoted = false;
  const source = String(textValue || '').replace(/^\uFEFF/, '');
  for (let i = 0; i < source.length; i += 1) {
    const char = source[i];
    const next = source[i + 1];
    if (quoted) {
      if (char === '"' && next === '"') {
        cell += '"';
        i += 1;
      } else if (char === '"') {
        quoted = false;
      } else {
        cell += char;
      }
      continue;
    }
    if (char === '"') {
      quoted = true;
      continue;
    }
    if (char === ',') {
      row.push(cleanCell(cell));
      cell = '';
      continue;
    }
    if (char === '\n') {
      row.push(cleanCell(cell));
      rows.push(row);
      row = [];
      cell = '';
      continue;
    }
    if (char !== '\r') cell += char;
  }
  if (cell || row.length) {
    row.push(cleanCell(cell));
    rows.push(row);
  }
  return rows.filter(function(item) {
    return item.some(function(cellValue) { return cleanCell(cellValue); });
  });
}

function decodeCsvBuffer(buffer) {
  const raw = Buffer.isBuffer(buffer) ? buffer : Buffer.from(buffer || '');
  if (raw.length >= 2 && raw[0] === 0xFF && raw[1] === 0xFE) return raw.toString('utf16le');
  if (raw.length >= 2 && raw[0] === 0xFE && raw[1] === 0xFF) return raw.swap16().toString('utf16le');
  return raw.toString('utf8');
}

function normalizeProjectToken(value) {
  return normalizedText(value)
    .replace(/����|����|��Ŀ|��Ϸ|����/g, '')
    .replace(/[��������\[\]()����]/g, '');
}

function crmNumber(value) {
  return num(cleanCell(value).replace(/,/g, ''));
}

function normalizeCrmExecutionRow(row) {
  row = row || {};
  return {
    orderNo: cleanCell(row[''] || row['']),
    executor: cleanCell(row['执行媒介']),
    inquiryMedia: cleanCell(row['询单媒介']),
    customerName: cleanCell(row['客户名称']),
    marketingTarget: cleanCell(row['营销标的']),
    assetOwner: cleanCell(row['']),
    nickname: cleanCell(row['昵称']),
    originalId: cleanCell(row['原id']),
    account: cleanCell(row['账号']),
    uid: cleanCell(row['UID']),
    videoId: cleanCell(row['视频ID']),
    publishUrl: cleanCell(row['发布链接']),
    publishedAt: cleanCell(row['实际发布时间']),
    platform: cleanCell(row['平台']),
    title: cleanCell(row['标题']),
    contractPrice: crmNumber(row['合同价格']),
    douPlusCost: crmNumber(row['抖加购买费用']),
    douPlusPlay: crmNumber(row['']),
    exposure: crmNumber(row['']),
    play: crmNumber(row['']),
    validPlay: crmNumber(row['']),
    naturalPlay: crmNumber(row['']),
    comment: crmNumber(row[''] || row['']),
    like: crmNumber(row['']),
    share: crmNumber(row[''] || row['']),
    favorite: crmNumber(row[''] || row['']),
    expectedCpm: crmNumber(row['预期CPM']),
    cpm: crmNumber(row['cpm']),
    updatedAt: cleanCell(row['更新时间']),
    play3d: crmNumber(row[''] || row['']),
    play7d: crmNumber(row[''] || row['']),
    play15d: crmNumber(row[''] || row['']),
    play30d: crmNumber(row[''] || row['']),
    like7d: crmNumber(row[''] || row['']),
    favorite7d: crmNumber(row[''] || row['']),
    comment7d: crmNumber(row[''] || row['']),
    share7d: crmNumber(row[''] || row[''] || row['']),
    targetCpm: crmNumber(row['目标CPM']),
    targetPlay: crmNumber(row['']),
    targetLike: crmNumber(row['']),
    targetComment: crmNumber(row['']),
    targetFavorite: crmNumber(row['']),
    guaranteeDeadline: cleanCell(row['保量截止时间']),
    followStatus: cleanCell(row['保量跟进']),
    matchProjectToken: normalizeProjectToken(row['营销标的']),
    matchAccountToken: normalizedText(row['昵称']),
    raw: row
  };
}

function latestCrmCsvFile() {
  const downloads = path.join(os.homedir(), 'Downloads');
  let files = [];
  try {
    files = fs.readdirSync(downloads, { withFileTypes: true })
      .filter(function(entry) { return entry.isFile() && /^达人执行效果列表.*\.csv$/i.test(entry.name); })
      .map(function(entry) {
        const fullPath = path.join(downloads, entry.name);
        const stat = fs.statSync(fullPath);
        return { path: fullPath, name: entry.name, size: stat.size, mtimeMs: stat.mtimeMs };
      })
      .sort(function(a, b) { return b.mtimeMs - a.mtimeMs; });
  } catch (e) {}
  return files[0] || null;
}

function readLatestCrmCsv() {
  const file = latestCrmCsvFile();
  if (!file) return { ok: false, error: '' };
  const parsed = parseCsv(decodeCsvBuffer(fs.readFileSync(file.path)));
  if (parsed.length < 2) return { ok: false, error: '', file: file };
  const headers = parsed[0].map(cleanCell);
  const rows = parsed.slice(1).map(function(cells) {
    const row = {};
    headers.forEach(function(header, index) {
      row[header] = cleanCell(cells[index]);
    });
    return row;
  });
  const normalizedRows = rows
    .map(normalizeCrmExecutionRow)
    .filter(function(row) { return row.nickname || row.marketingTarget || row.videoId || row.publishUrl; });
  return {
    ok: true,
    source: 'crm-execution-csv',
    file: file,
    headers: headers,
    rows: normalizedRows,
    count: normalizedRows.length
  };
}

function timestamp(value) {
  if (!value) return nowSec();
  const time = new Date(value).getTime();
  return Number.isFinite(time) ? Math.floor(time / 1000) : nowSec();
}

function userKey(body) {
  const auth = body._auth || {};
  return auth.username || auth.display_name || 'default';
}

function maintenanceScopeKey(body) {
  const group = text(body.groupName || body.group || body.state && (body.state.groupName || body.state.group));
  return group ? ('maintenance:' + group) : userKey(body);
}

function trafficScopeKey(body) {
  const group = text(body.groupName || body.group || body.state && (body.state.groupName || body.state.group));
  return group ? ('traffic:' + group) : userKey(body);
}

function stateFromBody(body) {
  const state = body.state && typeof body.state === 'object' ? body.state : body;
  return {
    plans: Array.isArray(state.plans) ? state.plans : [],
    importedVideos: Array.isArray(state.importedVideos) ? state.importedVideos : [],
    accountLibrary: Array.isArray(state.accountLibrary) ? state.accountLibrary : [],
    applyRequests: Array.isArray(state.applyRequests) ? state.applyRequests : []
  };
}

function run(db, sql, params) {
  return new Promise(function(resolve, reject) {
    db.run(sql, params || [], function(err) {
      if (err) reject(err);
      else resolve({ lastID: this.lastID, changes: this.changes });
    });
  });
}

function all(db, sql, params) {
  return new Promise(function(resolve, reject) {
    db.all(sql, params || [], function(err, rows) {
      if (err) reject(err);
      else resolve(rows || []);
    });
  });
}

function get(db, sql, params) {
  return new Promise(function(resolve, reject) {
    db.get(sql, params || [], function(err, row) {
      if (err) reject(err);
      else resolve(row || null);
    });
  });
}

function closeDb(db) {
  try { db.close(); } catch (e) {}
}

function safeSessionName(value) {
  const seed = text(value).split('').reduce(function(sum, char) {
    return (sum * 31 + char.charCodeAt(0)) >>> 0;
  }, 7);
  return 'traffic-xingtu-' + seed.toString(36);
}

function stripAnsi(value) {
  return String(value || '');
}

function parseOpencliJson(stdout) {
  const clean = stripAnsi(stdout).trim();
  const lines = clean.split(/\r?\n/).map(function(line) { return line.trim(); }).filter(Boolean);
  const candidates = [clean].concat(lines.slice().reverse());
  const firstBrace = clean.indexOf('{');
  const lastBrace = clean.lastIndexOf('}');
  if (firstBrace >= 0 && lastBrace > firstBrace) candidates.push(clean.slice(firstBrace, lastBrace + 1));
  for (const candidate of candidates) {
    try {
      let parsed = JSON.parse(candidate);
      if (typeof parsed === 'string') {
        parsed = JSON.parse(parsed);
      }
      if (parsed && typeof parsed === 'object') return parsed;
    } catch (e) {}
  }
  return null;
}

function extractFirstUrl(value) {
  const match = String(value || '').match(/https?:\/\/[^\s"'<>????????????\])}]+/i);
  return match ? match[0] : '';
}

function extractDouyinAwemeId(value) {
  const raw = String(value || '');
  if (/^\d{8,}$/.test(raw.trim())) return raw.trim();
  const direct = raw.match(/\/video\/(\d{8,})/i);
  if (direct) return direct[1];
  const note = raw.match(/\/note\/(\d{8,})/i);
  if (note) return note[1];
  const modal = raw.match(/[?&](?:modal_id|aweme_id|item_id)=([^&#\s]+)/i);
  if (modal && /^\d{8,}$/.test(modal[1])) return modal[1];
  return '';
}

function resolveRedirect(url, limit) {
  return new Promise(function(resolve) {
    const target = String(url || '').trim();
    if (!/^https?:\/\//i.test(target) || (limit || 0) > 5) return resolve(target);
    const client = target.indexOf('https://') === 0 ? require('https') : require('http');
    const req = client.request(target, { method: 'HEAD', timeout: 12000, headers: { 'User-Agent': 'Mozilla/5.0' } }, function(res) {
      const location = res.headers.location;
      res.resume();
      if (location && res.statusCode >= 300 && res.statusCode < 400) {
        resolveRedirect(new URL(location, target).toString(), (limit || 0) + 1).then(resolve);
      } else {
        resolve(target);
      }
    });
    req.on('timeout', function() {
      try { req.destroy(); } catch (e) {}
      resolve(target);
    });
    req.on('error', function() { resolve(target); });
    req.end();
  });
}

function firstObjectFromStats(parsed) {
  if (Array.isArray(parsed)) return parsed.find(function(item) { return item && typeof item === 'object'; }) || null;
  if (!parsed || typeof parsed !== 'object') return null;
  const candidates = [
    parsed,
    parsed.data,
    parsed.item,
    parsed.aweme,
    parsed.aweme_detail,
    parsed.video,
    parsed.result
  ];
  for (let i = 0; i < candidates.length; i += 1) {
    const item = candidates[i];
    if (item && typeof item === 'object' && !Array.isArray(item)) return item;
  }
  return null;
}

function douyinStatsFromObject(item, awemeId, url) {
  item = item || {};
  const stat = item.statistics || item.stats || item.stat || {};
  return {
    title: text(item.title || item.desc || item.description || item.name),
    awemeId: text(item.aweme_id || item.awemeId || item.id || awemeId),
    url: text(url || item.url || item.share_url || item.video_url || (awemeId ? ('https://www.douyin.com/video/' + awemeId) : '')),
    stats: {
      play: num(item.play || item.plays || item.view || item.views || item.play_count || stat.play_count || stat.view_count),
      like: num(item.like || item.likes || item.like_count || item.digg_count || stat.like_count || stat.digg_count),
      comment: num(item.comment || item.comments || item.comment_count || stat.comment_count),
      favorite: num(item.favorite || item.favorites || item.collect || item.collects || item.collect_count || stat.collect_count || stat.favorite_count),
      share: num(item.share || item.shares || item.share_count || stat.share_count)
    },
    raw: item
  };
}

function runOpencli(args, timeoutMs) {
  return new Promise(function(resolve) {
    const opencliPath = process.env.OPENCLI_BIN || process.env.USAGI_OPENCLI_PATH ||
      (process.platform === 'win32' ? path.join(os.homedir(), 'AppData', 'Roaming', 'npm', 'opencli.cmd') : 'opencli');
    const command = process.platform === 'win32' ? 'cmd.exe' : opencliPath;
    const spawnArgs = process.platform === 'win32'
      ? ['/d', '/s', '/c', opencliPath].concat(args)
      : args;
    const child = spawn(command, spawnArgs, {
      shell: false,
      env: Object.assign({}, process.env)
    });
    const out = [];
    const err = [];
    let settled = false;
    const timer = setTimeout(function() {
      if (settled) return;
      settled = true;
      try { child.kill(); } catch (e) {}
      resolve({ ok: false, code: -1, stdout: Buffer.concat(out).toString('utf8'), stderr: 'opencli timeout' });
    }, timeoutMs || 45000);

    child.stdout.on('data', function(chunk) { out.push(Buffer.from(chunk)); });
    child.stderr.on('data', function(chunk) { err.push(Buffer.from(chunk)); });
    child.on('error', function(error) {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      resolve({ ok: false, code: -1, stdout: Buffer.concat(out).toString('utf8'), stderr: error.message || String(error) });
    });
    child.on('close', function(code) {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      resolve({
        ok: code === 0,
        code: code,
        stdout: Buffer.concat(out).toString('utf8'),
        stderr: Buffer.concat(err).toString('utf8')
      });
    });
  });
}

async function fetchDouyinVideoStats(params) {
  const rawInput = text(params.url || params.videoUrl || params.awemeId || params.videoId);
  const sourceUrl = extractFirstUrl(rawInput) || rawInput;
  if (!sourceUrl) return { ok: false, error: '请先填写抖音视频链接' };
  const resolvedUrl = await resolveRedirect(sourceUrl);
  const awemeId = extractDouyinAwemeId(resolvedUrl) || extractDouyinAwemeId(sourceUrl);
  if (!awemeId) {
    return { ok: false, error: '', resolvedUrl: resolvedUrl || sourceUrl };
  }
  const profile = text(params.opencliProfile || process.env.DOUYIN_OPENCLI_PROFILE || process.env.OPENCLI_PROFILE || process.env.XINGTU_OPENCLI_PROFILE || 'd84u4a2b');
  const args = (profile ? ['--profile', profile] : []).concat(['douyin', 'stats', awemeId, '-f', 'json']);
  const result = await runOpencli(args, 90000);
  const parsed = result.ok ? parseOpencliJson(result.stdout) : null;
  const item = firstObjectFromStats(parsed);
  if (!result.ok || !item) {
    const pageResult = await fetchDouyinStatsFromPage({
      url: resolvedUrl || sourceUrl,
      opencliProfile: profile
    });
    if (pageResult && pageResult.ok) {
      return Object.assign({}, pageResult, {
        awemeId: awemeId,
        statsError: stripAnsi(result.stderr || result.stdout).trim()
      });
    }
    return {
      ok: false,
      error: pageResult && pageResult.error
        ? ('douyin stats failed; page fallback failed: ' + pageResult.error)
        : (stripAnsi(result.stderr || result.stdout).trim() || 'douyin opencli stats failed'),
      detail: pageResult && pageResult.detail || '',
      awemeId: awemeId,
      resolvedUrl: resolvedUrl || sourceUrl
    };
  }
  const data = douyinStatsFromObject(item, awemeId, resolvedUrl || sourceUrl);
  return {
    ok: true,
    source: 'douyin-opencli',
    profile: profile,
    awemeId: data.awemeId || awemeId,
    url: data.url || resolvedUrl || sourceUrl,
    title: data.title,
    stats: data.stats,
    raw: data.raw
  };
}

function opencliBrowserArgs(profile, session, command, extra) {
  const args = [];
  if (profile) args.push('--profile', profile);
  return args.concat(['browser', session, command], extra || []);
}

function normalizeXingtuVideo(item) {
  item = item || {};
  return {
    date: text(item.date || item.item_date || item.create_time || item.publish_time),
    title: text(item.title || item.item_title || item.desc),
    item_id: text(item.item_id || item.itemId || item.video_id || item.aweme_id),
    play: num(item.play || item.play_count || item.play_cnt),
    like: num(item.like || item.like_count || item.digg_count),
    comment: num(item.comment || item.comment_count),
    share: num(item.share || item.share_count),
    url: text(item.url || item.item_url || item.share_url),
    importedAt: new Date().toISOString(),
    source: 'xingtu-opencli'
  };
}

function normalizeXingtuUrl(value) {
  const raw = text(value);
  if (!raw) return '';
  try {
    const parsed = new URL(raw);
    if (/xingtu\.cn$/i.test(parsed.hostname) || /\.xingtu\.cn$/i.test(parsed.hostname)) {
      parsed.search = '';
      parsed.hash = '';
      return parsed.toString();
    }
  } catch (e) {}
  return raw.split(/[?#]/)[0] || raw;
}

const XINGTU_READ_JS = `JSON.stringify((() => {
  const parseMetric = value => {
    const text = String(value || '').trim().replace(/,/g, '');
    const match = text.match(/([\\d.]+)\\s*([w��kǧ]?)/i);
    if (!match) return Number(text) || 0;
    const base = Number(match[1]) || 0;
    const unit = String(match[2] || '').toLowerCase();
    if (unit === 'w' || unit === '��') return Math.round(base * 10000);
    if (unit === 'k' || unit === 'ǧ') return Math.round(base * 1000);
    return base;
  };
  const readTrendPanel = () => {
    const panel = document.querySelector('.video-trend-panel');
    const st = panel?.__vue__?.$parent?._setupState;
    const unwrap = value => value && typeof value === 'object' && 'value' in value ? value.value : value;
    const list = unwrap(st?.videoInfoList) || [];
    const trend = unwrap(st?.videoTrendData) || {};
    if (!st || !Array.isArray(list) || !list.length) return null;
    return {
      sourceMode: 'video-trend-panel',
      latest: trend.latest_item_info || null,
      videos: list.map(item => ({
        date: item.item_date || item.date || item.create_time || '',
        title: item.item_title || item.title || '',
        item_id: String(item.item_id || item.itemId || item.video_id || ''),
        play: Number(item.play || item.play_count || 0),
        like: Number(item.like || item.like_count || 0),
        comment: Number(item.comment || item.comment_count || 0),
        share: Number(item.share || item.share_count || 0),
        url: item.url || item.item_url || item.share_url || ''
      }))
    };
  };
  const readCreativeCards = () => {
    const cards = Array.from(document.querySelectorAll('.content-video-card'));
    if (!cards.length) return null;
    return {
      sourceMode: 'creative-cards',
      latest: null,
      videos: cards.map((card, index) => {
        const lines = String(card.innerText || '').split(/\\n+/).map(line => line.trim()).filter(Boolean);
        const metric = label => {
          const normalizedLabel = String(label || '').replace(/\\s+/g, '');
          const idx = lines.findIndex(line => String(line || '').replace(/\\s+/g, '').includes(normalizedLabel));
          return idx >= 0 ? lines[idx + 1] || '' : '';
        };
        return {
          date: '',
          title: lines[1] || lines[0] || '',
          item_id: '',
          tag: lines[0] || '',
          play: parseMetric(metric('播放�?)),
          like: parseMetric(metric('点赞�?)),
          comment: parseMetric(metric('评论�?)),
          share: 0,
          url: '',
          rank: index
        };
      }).filter(item => item.title || item.play || item.like || item.comment)
    };
  };
  const data = readTrendPanel() || readCreativeCards();
  if (!data || !Array.isArray(data.videos) || !data.videos.length) {
    return { ok: false, error: String(document.body?.innerText || '').slice(0, 800) };
  }
  return { ok: true, url: location.href, title: document.title, ...data };
})())`;

function compactJs(value) {
  return String(value || '')
    .replace(/\/\*[\s\S]*?\*\//g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function browserEvalArg(js) {
  return "eval(atob('" + Buffer.from(String(js || ''), 'utf8').toString('base64') + "'))";
}

const DOUYIN_READ_PAGE_JS = `JSON.stringify((() => {
  const parseMetric = value => {
    const text = String(value || '').trim().replace(/,/g, '');
    const match = text.match(/^([\\d.]+)\\s*([w��kǧ]?)$/i);
    if (!match) return 0;
    const base = Number(match[1]) || 0;
    const unit = String(match[2] || '').toLowerCase();
    if (unit === 'w' || unit === '��') return Math.round(base * 10000);
    if (unit === 'k' || unit === 'ǧ') return Math.round(base * 1000);
    return Math.round(base);
  };
  const lines = String(document.body?.innerText || '').split(/\\n+/).map(line => line.trim()).filter(Boolean);
  const pageTitle = String(document.title || '').replace(/\\s*-\\s*抖音.*$/, '').trim();
  if (lines.some(line => /视频不存在|作品不存在|已删�?.test(line))) {
    return { ok: false, error: '抖音页面提示视频不存在或已删�?, title: pageTitle, url: location.href };
  }
  const titleIndex = lines.findIndex(line => {
    if (!pageTitle || pageTitle.length < 4) return false;
    const head = pageTitle.slice(0, Math.min(24, pageTitle.length));
    return line === pageTitle || line.includes(head) || pageTitle.includes(line.slice(0, Math.min(24, line.length)));
  });
  const start = titleIndex >= 0 ? titleIndex + 1 : 0;
  const stopIndex = lines.findIndex((line, index) => index > start && /^(举报|发布时间|全部评论|相关推荐|推荐视频)$/.test(line));
  const metricArea = lines.slice(start, stopIndex > start ? stopIndex : start + 18);
  const metricTexts = metricArea.filter(line => /^[\\d,.]+\\s*([wW万kK千])?$/.test(line)).slice(0, 4);
  if (metricTexts.length < 2) {
    return { ok: false, error: '抖音页面已打开，但没有识别到互动数�?, title: pageTitle, url: location.href, sample: lines.slice(Math.max(0, start - 4), start + 20) };
  }
  return {
    ok: true,
    title: pageTitle,
    url: location.href,
    stats: {
      like: parseMetric(metricTexts[0]),
      comment: parseMetric(metricTexts[1]),
      favorite: parseMetric(metricTexts[2]),
      share: parseMetric(metricTexts[3])
    },
    metricTexts
  };
})())`;

async function fetchDouyinStatsFromPage(params) {
  const url = text(params.url || params.videoUrl || params.resolvedUrl);
  if (!url) return { ok: false, error: '请先填写抖音视频链接' };
  const profile = text(params.opencliProfile || process.env.DOUYIN_OPENCLI_PROFILE || process.env.OPENCLI_PROFILE || process.env.XINGTU_OPENCLI_PROFILE || 'd84u4a2b');
  const session = 'traffic-douyin-' + safeSessionName(url).replace(/^traffic-xingtu-/, '');
  const open = await runOpencli(opencliBrowserArgs(profile, session, 'open', [url]), 45000);
  if (!open.ok) {
    return { ok: false, error: stripAnsi(open.stderr || open.stdout).trim() || 'opencli 打开抖音视频失败' };
  }
  await runOpencli(opencliBrowserArgs(profile, session, 'wait', ['--timeout', '15000', 'selector', 'body']), 20000);
  const evaluated = await runOpencli(opencliBrowserArgs(profile, session, 'eval', [browserEvalArg(DOUYIN_READ_PAGE_JS)]), 30000);
  if (!evaluated.ok) {
    return { ok: false, error: stripAnsi(evaluated.stderr || evaluated.stdout).trim() || '抖音页面互动读取失败' };
  }
  const parsed = parseOpencliJson(evaluated.stdout);
  if (!parsed || !parsed.ok) {
    return {
      ok: false,
      error: parsed && parsed.error || '抖音页面没有返回可用互动数据',
      detail: parsed && parsed.sample ? parsed.sample.join(' / ') : stripAnsi(evaluated.stdout).slice(0, 300)
    };
  }
  return {
    ok: true,
    source: 'douyin-page-opencli',
    profile: profile,
    title: parsed.title || '',
    url: parsed.url || url,
    stats: parsed.stats || {},
    metricTexts: parsed.metricTexts || []
  };
}

async function fetchXingtuVideos(params) {
  const xingtuUrl = normalizeXingtuUrl(params.xingtuUrl || params.authorUrl || params.creatorUrl);
  if (!xingtuUrl) {
    return { ok: false, error: '请先填写达人星图主页链接' };
  }
  const profile = text(params.opencliProfile || process.env.XINGTU_OPENCLI_PROFILE || process.env.OPENCLI_PROFILE || 'd84u4a2b');
  const session = safeSessionName(xingtuUrl);
  const open = await runOpencli(opencliBrowserArgs(profile, session, 'open', [xingtuUrl]), 45000);
  if (!open.ok) {
    return {
      ok: false,
      error: stripAnsi(open.stderr || open.stdout).trim() || 'opencli 打开星图失败'
    };
  }

  await runOpencli(opencliBrowserArgs(profile, session, 'wait', ['--timeout', '12000', 'selector', 'body']), 15000);
  const evaluated = await runOpencli(opencliBrowserArgs(profile, session, 'eval', [browserEvalArg(XINGTU_READ_JS)]), 30000);
  if (!evaluated.ok) {
    return {
      ok: false,
      error: stripAnsi(evaluated.stderr || evaluated.stdout).trim() || '星图页面数据读取失败'
    };
  }
  const parsed = parseOpencliJson(evaluated.stdout);
  if (!parsed || !parsed.ok) {
    return {
      ok: false,
      error: parsed && parsed.error || '星图页面没有返回可用视频数据',
      raw: stripAnsi(evaluated.stdout).slice(0, 500)
    };
  }
  const videos = (Array.isArray(parsed.videos) ? parsed.videos : [])
    .map(normalizeXingtuVideo)
    .filter(function(item) { return item.item_id || item.url || item.title; });
  return {
    ok: true,
    source: 'xingtu-opencli',
    sourceMode: parsed.sourceMode || '',
    profile: profile,
    xingtuUrl: xingtuUrl,
    pageUrl: parsed.url || xingtuUrl,
    videos: videos,
    latest: parsed.latest || null,
    count: videos.length
  };
}

module.exports = function createTrafficPlanRoutes(deps) {
  const root = deps.root || path.join(__dirname, '..', '..');
  const runPython = deps.runPython;
  const dataDir = path.join(root, 'data');
  const dbPath = path.join(dataDir, 'traffic_plan.db');
  if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });

  const adapter = createSqliteAdapter({ dbPath: dbPath, logger: logger });
  function getDb() {
    return adapter.createDb();
  }

  async function initSchema() {
    const db = getDb();
    try {
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_projects (
        user_key      TEXT NOT NULL,
        project_key   TEXT NOT NULL,
        project_name  TEXT NOT NULL,
        platform      TEXT DEFAULT '',
        schedule_date TEXT DEFAULT '',
        target_cpm    REAL DEFAULT 0,
        payload       TEXT NOT NULL,
        created_at    INTEGER DEFAULT 0,
        updated_at    INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, project_key)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_account_executions (
        user_key      TEXT NOT NULL,
        id            TEXT NOT NULL,
        project_key   TEXT NOT NULL,
        account_group TEXT DEFAULT '',
        account_name  TEXT DEFAULT '',
        platform      TEXT DEFAULT '',
        order_amount  REAL DEFAULT 0,
        budget        REAL DEFAULT 0,
        target_cpm    REAL DEFAULT 0,
        target_play   REAL DEFAULT 0,
        actual_play   REAL DEFAULT 0,
        video_url     TEXT DEFAULT '',
        xingtu_url    TEXT DEFAULT '',
        payload       TEXT NOT NULL,
        created_at    INTEGER DEFAULT 0,
        updated_at    INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, id)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_batches (
        user_key     TEXT NOT NULL,
        id           TEXT NOT NULL,
        execution_id TEXT NOT NULL,
        project_key  TEXT NOT NULL,
        demand_id    TEXT DEFAULT '',
        demand_name  TEXT DEFAULT '',
        status       TEXT DEFAULT '',
        traffic_type TEXT DEFAULT '',
        budget       REAL DEFAULT 0,
        target_play  REAL DEFAULT 0,
        payload      TEXT NOT NULL,
        created_at   INTEGER DEFAULT 0,
        updated_at   INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, id)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_account_library (
        user_key      TEXT NOT NULL,
        account_group TEXT DEFAULT '',
        account_name  TEXT NOT NULL,
        platform      TEXT DEFAULT '',
        xingtu_url    TEXT DEFAULT '',
        payload       TEXT NOT NULL,
        created_at    INTEGER DEFAULT 0,
        updated_at    INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, account_group, account_name)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_imported_videos (
        user_key    TEXT NOT NULL,
        id          TEXT NOT NULL,
        account_name TEXT DEFAULT '',
        title       TEXT DEFAULT '',
        url         TEXT DEFAULT '',
        item_id     TEXT DEFAULT '',
        payload     TEXT NOT NULL,
        created_at  INTEGER DEFAULT 0,
        updated_at  INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, id)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_apply_requests (
        user_key     TEXT NOT NULL,
        id           TEXT NOT NULL,
        project_name TEXT DEFAULT '',
        account_name TEXT DEFAULT '',
        platform     TEXT DEFAULT '',
        phase_name   TEXT DEFAULT '',
        budget       REAL DEFAULT 0,
        target_play  REAL DEFAULT 0,
        payload      TEXT NOT NULL,
        created_at   INTEGER DEFAULT 0,
        updated_at   INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, id)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_maintenance_records (
        user_key     TEXT NOT NULL,
        id           TEXT NOT NULL,
        group_name   TEXT DEFAULT '',
        target_name  TEXT DEFAULT '',
        account_name TEXT DEFAULT '',
        phase_name   TEXT DEFAULT '',
        payload      TEXT NOT NULL,
        created_at   INTEGER DEFAULT 0,
        updated_at   INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, id)
      )`);
      await run(db, `CREATE TABLE IF NOT EXISTS traffic_maintenance_group_configs (
        user_key    TEXT NOT NULL,
        group_name  TEXT NOT NULL,
        payload     TEXT NOT NULL,
        updated_at  INTEGER DEFAULT 0,
        PRIMARY KEY (user_key, group_name)
      )`);
      await run(db, 'CREATE INDEX IF NOT EXISTS idx_traffic_exec_project ON traffic_account_executions(user_key, project_key)');
      await run(db, 'CREATE INDEX IF NOT EXISTS idx_traffic_batch_exec ON traffic_batches(user_key, execution_id)');
      await run(db, 'CREATE INDEX IF NOT EXISTS idx_traffic_maintenance_group ON traffic_maintenance_records(user_key, group_name, updated_at)');
    } finally {
      closeDb(db);
    }
  }

  const ready = initSchema();

  function withReady(cb, done) {
    ready.then(cb).catch(function(err) {
      done({ ok: false, error: err.message || String(err) });
    });
  }

  function projectKey(plan) {
    return text(plan.projectId || plan.projectKey || plan.projectInstanceId || plan.projectName || plan.marketingTarget || '未命名项�?);
  }

  function projectDisplayName(plan) {
    return text(plan.projectName || plan.marketingTarget || plan.projectKey || plan.projectId || '未命名项�?);
  }

  function mergeTrafficStates(primary, fallback) {
    const projectMap = new Map();
    const planMap = new Map();
    const videoMap = new Map();
    const accountMap = new Map();
    const applyMap = new Map();

    function append(state) {
      if (!state) return;
      (state.projects || []).forEach(function(item) {
        const key = projectKey(item);
        if (key) projectMap.set(key, Object.assign({}, projectMap.get(key) || {}, item));
      });
      (state.plans || []).forEach(function(item) {
        const key = text(item.id) || [
          projectKey(item),
          text(item.accountName),
          text(item.videoUrl || item.videoId)
        ].join('|');
        if (key) planMap.set(key, Object.assign({}, planMap.get(key) || {}, item));
      });
      (state.importedVideos || []).forEach(function(item) {
        const key = text(item.id || item.item_id || item.itemId || item.url || item.title);
        if (key) videoMap.set(key, Object.assign({}, videoMap.get(key) || {}, item));
      });
      (state.accountLibrary || []).forEach(function(item) {
        const key = [text(item.accountGroup || item.group), text(item.accountName || item.name)].join('|');
        if (text(item.accountName || item.name)) accountMap.set(key, Object.assign({}, accountMap.get(key) || {}, item));
      });
      (state.applyRequests || []).forEach(function(item) {
        const key = text(item.id) || [text(item.projectName), text(item.accountName), text(item.phaseName)].join('|');
        if (key) applyMap.set(key, Object.assign({}, applyMap.get(key) || {}, item));
      });
    }

    append(fallback);
    append(primary);
    return {
      ok: true,
      dbPath: dbPath,
      scopeKey: primary && primary.scopeKey || '',
      legacyKey: fallback && fallback.scopeKey || '',
      projects: Array.from(projectMap.values()),
      plans: Array.from(planMap.values()),
      importedVideos: Array.from(videoMap.values()),
      accountLibrary: Array.from(accountMap.values()),
      applyRequests: Array.from(applyMap.values()),
      updatedAt: Math.max(primary && primary.updatedAt || 0, fallback && fallback.updatedAt || 0)
    };
  }

  async function readState(key) {
    const db = getDb();
    try {
      const projectRows = await all(db, '', [key]);
      const executionRows = await all(db, '', [key]);
      const videoRows = await all(db, '', [key]);
      const accountRows = await all(db, '', [key]);
      const applyRows = await all(db, '', [key]);
      const meta = await get(db, `SELECT MAX(updated_at) AS updated_at FROM (
        SELECT updated_at FROM traffic_projects WHERE user_key=?
        UNION ALL SELECT updated_at FROM traffic_account_executions WHERE user_key=?
        UNION ALL SELECT updated_at FROM traffic_imported_videos WHERE user_key=?
        UNION ALL SELECT updated_at FROM traffic_account_library WHERE user_key=?
        UNION ALL SELECT updated_at FROM traffic_apply_requests WHERE user_key=?
      )`, [key, key, key, key, key]);

      return {
        ok: true,
        dbPath: dbPath,
        scopeKey: key,
        projects: projectRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        plans: executionRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        importedVideos: videoRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        accountLibrary: accountRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        applyRequests: applyRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        updatedAt: meta && meta.updated_at || 0
      };
    } finally {
      closeDb(db);
    }
  }

  async function readGroupTasks(groupName, legacyKey) {
    const groupKey = 'traffic:' + text(groupName);
    const group = text(groupName);
    const keys = Array.from(new Set([groupKey, legacyKey].map(text).filter(Boolean)));
    const db = getDb();
    try {
      const scopedRows = await all(db, `SELECT payload FROM traffic_account_executions
        WHERE user_key IN (${keys.map(function() { return ''; }).join(',')})
        ORDER BY updated_at DESC`, keys);
      const groupRows = group
        ? await all(db, 'SELECT payload, account_group FROM traffic_account_executions ORDER BY updated_at DESC', [])
        : [];
      const map = new Map();
      groupRows.filter(function(row) {
          const plan = parseJson(row.payload, {});
          return normalizedText(row.account_group || plan.accountGroup || plan.groupName) === normalizedText(group);
        })
        .concat(scopedRows)
        .map(function(row) { return parseJson(row.payload, {}); })
        .filter(Boolean)
        .filter(function(plan) {
          if (!group) return true;
          return normalizedText(plan.accountGroup || plan.groupName) === normalizedText(group);
        })
        .forEach(function(plan) {
        const key = text(plan.id) || [
          projectKey(plan),
          text(plan.accountName),
          text(plan.videoUrl || plan.videoId)
        ].join('|');
        if (key && !map.has(key)) map.set(key, plan);
      });
      return {
        ok: true,
        scopeKey: groupKey,
        legacyKey: legacyKey,
        count: map.size,
        plans: Array.from(map.values())
      };
    } finally {
      closeDb(db);
    }
  }

  async function readMaintenanceSources(groupName) {
    const group = text(groupName);
    const db = getDb();
    try {
      const rows = await all(db, 'SELECT payload, account_group FROM traffic_account_executions ORDER BY updated_at DESC', []);
      const map = new Map();
      rows.forEach(function(row) {
        const plan = parseJson(row.payload, {});
        if (!plan) return;
        const planGroup = text(row.account_group || plan.accountGroup || plan.groupName);
        if (group && normalizedText(planGroup) !== normalizedText(group)) return;
        const key = text(plan.id) || [
          projectKey(plan),
          text(plan.accountName),
          text(plan.videoUrl || plan.videoId)
        ].join('|');
        if (key && !map.has(key)) map.set(key, Object.assign({}, plan, { accountGroup: planGroup || plan.accountGroup || group }));
      });
      return {
        ok: true,
        groupName: group,
        count: map.size,
        plans: Array.from(map.values())
      };
    } finally {
      closeDb(db);
    }
  }

  async function saveState(key, incoming) {
    const state = stateFromBody(incoming);
    const replaceMode = Boolean(incoming && incoming.replaceState);
    if (!state.plans.length && !(incoming && incoming.allowEmptyPlans)) {
      const existing = await readState(key);
      if (existing && existing.plans && existing.plans.length) {
        state.plans = existing.plans;
        if (!state.importedVideos.length) state.importedVideos = existing.importedVideos || [];
        if (!state.applyRequests.length) state.applyRequests = existing.applyRequests || [];
      }
    }
    const db = getDb();
    const now = nowSec();
    try {
      if (replaceMode) {
        await run(db, '', [key]);
        await run(db, '', [key]);
        await run(db, '', [key]);
        await run(db, '', [key]);
        await run(db, '', [key]);
        await run(db, '', [key]);
      }

      const projectMap = new Map();
      state.plans.forEach(function(plan) {
        const keyName = projectKey(plan);
        if (!projectMap.has(keyName)) {
          projectMap.set(keyName, {
            projectKey: keyName,
            projectId: text(plan.projectId || plan.projectKey || plan.projectInstanceId),
            projectName: projectDisplayName(plan),
            platform: text(plan.platform),
            scheduleDate: text(plan.projectMeta && plan.projectMeta.scheduleDate),
            targetCpm: num(plan.targetCpm),
            accounts: [],
            createdAt: timestamp(plan.createdAt),
            updatedAt: timestamp(plan.updatedAt)
          });
        }
        const project = projectMap.get(keyName);
        project.accounts.push(text(plan.accountName));
        project.platform = project.platform || text(plan.platform);
        project.scheduleDate = project.scheduleDate || text(plan.projectMeta && plan.projectMeta.scheduleDate);
        project.targetCpm = project.targetCpm || num(plan.targetCpm);
        project.updatedAt = Math.max(project.updatedAt, timestamp(plan.updatedAt));
      });

      for (const project of projectMap.values()) {
        const payload = {
          projectKey: project.projectKey,
          projectId: project.projectId || project.projectKey,
          projectName: project.projectName,
          platform: project.platform,
          scheduleDate: project.scheduleDate,
          targetCpm: project.targetCpm,
          accounts: Array.from(new Set(project.accounts)).filter(Boolean),
          createdAt: new Date(project.createdAt * 1000).toISOString(),
          updatedAt: new Date(project.updatedAt * 1000).toISOString()
        };
        await run(db, `INSERT OR REPLACE INTO traffic_projects
          (user_key,project_key,project_name,platform,schedule_date,target_cpm,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?,?)`, [
          key,
          project.projectKey,
          project.projectName,
          project.platform,
          project.scheduleDate,
          project.targetCpm,
          jsonValue(payload),
          project.createdAt || now,
          project.updatedAt || now
        ]);
      }

      for (const plan of state.plans) {
        const id = text(plan.id) || ('traffic-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8));
        const pKey = projectKey(plan);
        const createdAt = timestamp(plan.createdAt);
        const updatedAt = timestamp(plan.updatedAt);
        await run(db, `INSERT OR REPLACE INTO traffic_account_executions
          (user_key,id,project_key,account_group,account_name,platform,order_amount,budget,target_cpm,target_play,actual_play,video_url,xingtu_url,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)`, [
          key,
          id,
          pKey,
          text(plan.accountGroup),
          text(plan.accountName),
          text(plan.platform),
          num(plan.orderAmount),
          num(plan.budget),
          num(plan.targetCpm),
          num(plan.targetPlay || plan.targetMetrics && plan.targetMetrics.play),
          num(plan.current && plan.current.play),
          text(plan.videoUrl || plan.videoId),
          text(plan.xingtuUrl || plan.authorUrl || plan.creatorUrl),
          jsonValue(Object.assign({}, plan, { id: id, projectId: text(plan.projectId || plan.projectKey || plan.projectInstanceId) || pKey, projectKey: pKey })),
          createdAt || now,
          updatedAt || now
        ]);

        const batches = Array.isArray(plan.batches) ? plan.batches : [];
        for (let i = 0; i < batches.length; i += 1) {
          const batch = batches[i] || {};
          const batchId = text(batch.id) || (id + '-batch-' + (i + 1));
          await run(db, `INSERT OR REPLACE INTO traffic_batches
            (user_key,id,execution_id,project_key,demand_id,demand_name,status,traffic_type,budget,target_play,payload,created_at,updated_at)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?)`, [
            key,
            batchId,
            id,
            pKey,
            text(batch.demandId || batch.phaseId),
            text(batch.demandName || batch.phaseName),
            text(batch.demandStatus || batch.status),
            text(batch.trafficType || plan.trafficType),
            num(batch.budget),
            num(batch.targetPlay),
            jsonValue(Object.assign({}, batch, { id: batchId })),
            timestamp(batch.createdAt || plan.createdAt) || now,
            timestamp(batch.updatedAt || plan.updatedAt) || now
          ]);
        }
      }

      for (const item of state.accountLibrary) {
        const accountName = text(item.accountName || item.name);
        if (!accountName) continue;
        await run(db, `INSERT OR REPLACE INTO traffic_account_library
          (user_key,account_group,account_name,platform,xingtu_url,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?)`, [
          key,
          text(item.accountGroup || item.group),
          accountName,
          text(item.platform),
          text(item.xingtuUrl || item.authorUrl || item.creatorUrl),
          jsonValue(Object.assign({}, item, { accountName: accountName })),
          timestamp(item.createdAt) || now,
          timestamp(item.updatedAt) || now
        ]);
      }

      for (let i = 0; i < state.importedVideos.length; i += 1) {
        const item = state.importedVideos[i] || {};
        const id = text(item.id || item.item_id || item.url || item.title) || ('video-' + i);
        await run(db, `INSERT OR REPLACE INTO traffic_imported_videos
          (user_key,id,account_name,title,url,item_id,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?,?)`, [
          key,
          id,
          text(item.accountName),
          text(item.title || item.item_title),
          text(item.url),
          text(item.item_id || item.itemId),
          jsonValue(item),
          timestamp(item.importedAt || item.createdAt) || now,
          timestamp(item.updatedAt || item.importedAt) || now
        ]);
      }

      for (const item of state.applyRequests) {
        const id = text(item.id) || ('apply-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8));
        await run(db, `INSERT OR REPLACE INTO traffic_apply_requests
          (user_key,id,project_name,account_name,platform,phase_name,budget,target_play,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?,?,?,?)`, [
          key,
          id,
          text(item.projectName),
          text(item.accountName),
          text(item.platform),
          text(item.phaseName),
          num(item.budget),
          num(item.targetPlay),
          jsonValue(Object.assign({}, item, { id: id })),
          timestamp(item.createdAt) || now,
          timestamp(item.updatedAt) || now
        ]);
      }

      return { ok: true, count: state.plans.length };
    } catch (err) {
      throw err;
    } finally {
      closeDb(db);
    }
  }

  async function deleteProjectState(key, projectName) {
    const pKey = text(projectName);
    if (!pKey) return { ok: false, error: '缺少项目�? };
    const db = getDb();
    try {
      const executionRows = await all(db, '', [key, pKey]);
      const executionIds = executionRows.map(function(row) { return text(row.id); }).filter(Boolean);
      await run(db, '', [key, pKey]);
      await run(db, '', [key, pKey]);
      await run(db, '', [key, pKey]);
      await run(db, '', [key, pKey]);
      return {
        ok: true,
        projectName: pKey,
        deletedExecutions: executionIds.length
      };
    } finally {
      closeDb(db);
    }
  }

  async function readMaintenanceState(key) {
    const db = getDb();
    try {
      const recordRows = await all(db, '', [key]);
      const configRows = await all(db, '', [key]);
      const meta = await get(db, `SELECT MAX(updated_at) AS updated_at FROM (
        SELECT updated_at FROM traffic_maintenance_records WHERE user_key=?
        UNION ALL SELECT updated_at FROM traffic_maintenance_group_configs WHERE user_key=?
      )`, [key, key]);
      return {
        ok: true,
        records: recordRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        groupConfigs: configRows.map(function(row) { return parseJson(row.payload, {}); }).filter(Boolean),
        updatedAt: meta && meta.updated_at || 0
      };
    } finally {
      closeDb(db);
    }
  }

  async function saveMaintenanceState(key, state) {
    const records = Array.isArray(state && state.records) ? state.records : [];
    const groupConfigs = Array.isArray(state && state.groupConfigs) ? state.groupConfigs : [];
    const db = getDb();
    const now = nowSec();
    try {
      await run(db, '', [key]);
      await run(db, '', [key]);
      for (const record of records) {
        const id = text(record.id) || ('maintenance-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8));
        await run(db, `INSERT OR REPLACE INTO traffic_maintenance_records
          (user_key,id,group_name,target_name,account_name,phase_name,payload,created_at,updated_at)
          VALUES (?,?,?,?,?,?,?,?,?)`, [
          key,
          id,
          text(record.groupName),
          text(record.targetName || record.projectName),
          text(record.accountName),
          text(record.phaseName),
          jsonValue(Object.assign({}, record, { id: id })),
          timestamp(record.createdAt) || now,
          timestamp(record.updatedAt) || now
        ]);
      }
      for (const config of groupConfigs) {
        const groupName = text(config.groupName || config.group) || '未分�?;
        await run(db, `INSERT OR REPLACE INTO traffic_maintenance_group_configs
          (user_key,group_name,payload,updated_at)
          VALUES (?,?,?,?)`, [
          key,
          groupName,
          jsonValue(Object.assign({}, config, { groupName: groupName })),
          timestamp(config.updatedAt) || now
        ]);
      }
      return { ok: true, records: records.length, groupConfigs: groupConfigs.length };
    } finally {
      closeDb(db);
    }
  }

  function crmPlatform(value) {
    const token = normalizedText(value);
    if (token.indexOf('douyin') >= 0 || token.indexOf('抖音') >= 0) return 'douyin';
    if (token.indexOf('bilibili') >= 0 || token.indexOf(''哔哩') >= 0) return 'bilibili';
    if (token.indexOf('kuaishou') >= 0 || token.indexOf('快手') >= 0) return 'kuaishou';
    if (token.indexOf(''视频�?) >= 0) return 'wechatVideo';
    return token;
  }

  function normalizePlanPlatform(value) {
    const platform = crmPlatform(value);
    if (platform === 'bilibili') return 'bilibili';
    if (platform === 'kuaishou') return 'kuaishou';
    if (platform === 'wechatVideo') return 'wechatVideo';
    if (platform === 'douyin') return 'douyin';
    return platform || 'douyin';
  }

  function normalizeVideoUrlForMatch(value) {
    const source = text(value);
    if (!source) return '';
    const matched = source.match(/https?:\/\/[^\s"'<>]+/i);
    const raw = matched ? matched[0] : source;
    try {
      const parsed = new URL(raw);
      parsed.hash = '';
      const keepParams = new URLSearchParams();
      ['item_id', 'video_id', 'aid', 'bvid'].forEach(function(key) {
        const paramValue = parsed.searchParams.get(key);
        if (paramValue) keepParams.set(key, paramValue);
      });
      parsed.search = keepParams.toString();
      return parsed.toString().replace(/\/$/, '');
    } catch (e) {
      return raw.replace(/[?#].*$/, '').replace(/\/$/, '');
    }
  }

  function extractDouyinVideoId(value) {
    const source = text(value);
    const direct = source.match(/(?:video\/|modal_id=|aweme_id=|item_id=)(\d{8,})/i);
    if (direct) return direct[1];
    return /^\d{8,}$/.test(source) ? source : '';
  }

  function sameCrmAccount(plan, row) {
    return Boolean(normalizedText(plan.accountName) && normalizedText(plan.accountName) === normalizedText(row.nickname));
  }

  function sameCrmProject(plan, row) {
    const planProject = normalizeProjectToken(plan.projectName || plan.marketingTarget);
    const rowProject = normalizeProjectToken(row.marketingTarget);
    return Boolean(planProject && rowProject && (planProject.indexOf(rowProject) >= 0 || rowProject.indexOf(planProject) >= 0));
  }

  function crmMatchReasons(plan, row) {
    const reasons = [];
    const planVideoId = normalizedText(extractDouyinVideoId(plan.videoId || plan.videoUrl));
    const rowVideoId = normalizedText(extractDouyinVideoId(row.videoId || row.publishUrl));
    const planUrl = normalizeVideoUrlForMatch(plan.videoUrl);
    const rowUrl = normalizeVideoUrlForMatch(row.publishUrl);
    if (planVideoId && rowVideoId && planVideoId === rowVideoId) reasons.push('视频ID');
    if (planUrl && rowUrl && planUrl === rowUrl) reasons.push('链接');
    if (sameCrmProject(plan, row)) reasons.push('标的');
    if (sameCrmAccount(plan, row)) reasons.push('账号');
    return reasons;
  }

  function scoreCrmMatch(plan, row, strict) {
    let score = 0;
    const reasons = crmMatchReasons(plan, row);
    if (reasons.indexOf('视频ID') >= 0) score += 120;
    if (reasons.indexOf('链接') >= 0) score += 110;
    if (strict && score <= 0) return 0;
    if (reasons.indexOf('账号') >= 0) score += 30;
    if (reasons.indexOf('标的') >= 0) score += 20;
    return score;
  }

  function bestCrmMatches(candidates, ambiguitySafeScore) {
    if (!candidates.length) return { rows: [], ambiguous: false, reason: '' };
    candidates.sort(function(a, b) {
      return b.score - a.score || text(b.row.updatedAt).localeCompare(text(a.row.updatedAt));
    });
    const bestScore = candidates[0].score;
    const best = candidates.filter(function(item) { return item.score === bestScore; });
    return {
      rows: best,
      ambiguous: best.length > 1 && bestScore < ambiguitySafeScore,
      reason: best.length > 1 ? 'CRM CSV 匹配不唯一' : ''
    };
  }

  function matchCrmRowsForPlan(plan, rows) {
    const planPlatform = normalizePlanPlatform(plan.platform);
    const sourceRows = (Array.isArray(rows) ? rows : []).filter(function(row) {
      return normalizePlanPlatform(row.platform) === planPlatform &&
        sameCrmProject(plan, row) &&
        sameCrmAccount(plan, row);
    });
    const planVideoId = extractDouyinVideoId(plan.videoId || plan.videoUrl);
    const planUrl = normalizeVideoUrlForMatch(plan.videoUrl);
    const strict = sourceRows
      .map(function(row) {
        return {
          row: row,
          reasons: crmMatchReasons(plan, row),
          score: scoreCrmMatch(plan, row, true),
          matchType: 'strict'
        };
      })
      .filter(function(item) {
        return item.reasons.indexOf('视频ID') >= 0 || item.reasons.indexOf('链接') >= 0;
      });
    if (strict.length) return bestCrmMatches(strict, 90);
    if (planVideoId) {
      return { rows: [], ambiguous: false, reason: '已填视频ID，但 CRM 未找到对应视�? };
    }

    const fallback = sourceRows
      .map(function(row) {
        return {
          row: row,
          reasons: crmMatchReasons(plan, row),
          score: scoreCrmMatch(plan, row, false),
          matchType: planUrl ? 'fallback-short-link' : 'fallback'
        };
      })
      .filter(function(item) {
        return item.score >= 45;
      });
    return bestCrmMatches(fallback, 60);
  }

  function metricNumber(value) {
    return num(value);
  }

  function mergeCrmMetrics(plan, row) {
    const current = Object.assign({}, plan.current || {});
    current.play = Math.max(metricNumber(current.play), metricNumber(row.play));
    current.like = Math.max(metricNumber(current.like), metricNumber(row.like));
    current.comment = Math.max(metricNumber(current.comment), metricNumber(row.comment));
    current.favorite = Math.max(metricNumber(current.favorite), metricNumber(row.favorite));
    current.share = Math.max(metricNumber(current.share), metricNumber(row.share));
    return current;
  }

  function crmMonitorPayload(row) {
    return {
      source: 'crm-execution-csv',
      orderNo: row.orderNo || '',
      executor: row.executor || '',
      inquiryMedia: row.inquiryMedia || '',
      customerName: row.customerName || '',
      marketingTarget: row.marketingTarget || '',
      assetOwner: row.assetOwner || '',
      nickname: row.nickname || '',
      account: row.account || '',
      uid: row.uid || '',
      platform: row.platform || '',
      title: row.title || '',
      publishedAt: row.publishedAt || '',
      contractPrice: metricNumber(row.contractPrice),
      douPlusCost: metricNumber(row.douPlusCost),
      douPlusPlay: metricNumber(row.douPlusPlay),
      exposure: metricNumber(row.exposure),
      play: metricNumber(row.play),
      validPlay: metricNumber(row.validPlay),
      naturalPlay: metricNumber(row.naturalPlay),
      comment: metricNumber(row.comment),
      like: metricNumber(row.like),
      favorite: metricNumber(row.favorite),
      share: metricNumber(row.share),
      expectedCpm: metricNumber(row.expectedCpm),
      cpm: metricNumber(row.cpm),
      updatedAt: row.updatedAt || '',
      play3d: metricNumber(row.play3d),
      play7d: metricNumber(row.play7d),
      play15d: metricNumber(row.play15d),
      play30d: metricNumber(row.play30d),
      like7d: metricNumber(row.like7d),
      favorite7d: metricNumber(row.favorite7d),
      comment7d: metricNumber(row.comment7d),
      share7d: metricNumber(row.share7d),
      guaranteeDeadline: row.guaranteeDeadline || '',
      followStatus: row.followStatus || ''
    };
  }

  function metricsChanged(left, right) {
    return ['play', 'like', 'comment', 'favorite', 'share'].some(function(key) {
      return metricNumber(left && left[key]) !== metricNumber(right && right[key]);
    });
  }

  function applyCrmRowsToState(state, rows) {
    let updated = 0;
    let skipped = 0;
    let conflicts = 0;
    const nowIso = new Date().toISOString();
    const plans = (state.plans || []).map(function(plan) {
      if (!['douyin', 'bilibili', 'kuaishou', 'wechatVideo'].includes(normalizePlanPlatform(plan.platform))) return plan;
      const matched = matchCrmRowsForPlan(plan, rows);
      if (!matched.rows.length) {
        skipped += 1;
        return Object.assign({}, plan, {
          syncMeta: Object.assign({}, plan.syncMeta || {}, {
            status: 'skipped',
            source: 'crm-execution-csv',
            message: matched.reason || 'CRM CSV 未匹配到项目账号',
            updatedAt: nowIso
          })
        });
      }
      if (matched.ambiguous) {
        conflicts += 1;
        return Object.assign({}, plan, {
          syncMeta: Object.assign({}, plan.syncMeta || {}, {
            status: 'skipped',
            source: 'crm-execution-csv',
            message: matched.reason || 'CRM CSV 匹配不唯一',
            updatedAt: nowIso
          })
        });
      }
      const item = matched.rows[0];
      const row = item.row;
      const current = mergeCrmMetrics(plan, row);
      const videoUrl = normalizeVideoUrlForMatch(row.publishUrl || plan.videoUrl);
      const videoId = extractDouyinVideoId(row.videoId || row.publishUrl) || extractDouyinVideoId(plan.videoId || plan.videoUrl);
      const changed = metricsChanged(plan.current, current) ||
        (videoUrl && videoUrl !== text(plan.videoUrl)) ||
        (videoId && videoId !== text(plan.videoId));
      if (changed) updated += 1;
      return Object.assign({}, plan, {
        current: current,
        videoUrl: videoUrl || plan.videoUrl,
        videoId: videoId || plan.videoId,
        videoTitle: row.title || plan.videoTitle,
        crmExecution: Object.assign({}, plan.crmExecution || {}, crmMonitorPayload(row)),
        syncMeta: Object.assign({}, plan.syncMeta || {}, {
          status: item.matchType === 'strict''ok' : 'fallback',
          source: 'crm-execution-csv',
          message: ''+') || '匹配'' · ' + row.marketingTarget : ''),
          updatedAt: nowIso
        }),
        updatedAt: nowIso
      });
    });
    return {
      state: Object.assign({}, state, { plans: plans }),
      updated: updated,
      skipped: skipped,
      conflicts: conflicts
    };
  }

  async function refreshCrmExecutionCsvState(options) {
    options = options || {};
    await ready;
    const crm = readLatestCrmCsv();
    if (!crm.ok) return Object.assign({ ok: false }, crm);
    const rows = Array.isArray(crm.rows) ? crm.rows : [];
    const db = getDb();
    let keys = [];
    try {
      keys = (await all(db, 'SELECT DISTINCT user_key FROM traffic_account_executions ORDER BY user_key', []))
        .map(function(row) { return text(row.user_key); })
        .filter(Boolean);
    } finally {
      closeDb(db);
    }
    let updated = 0;
    let skipped = 0;
    let conflicts = 0;
    let scopes = 0;
    for (const key of keys) {
      const state = await readState(key);
      if (!state.plans || !state.plans.length) continue;
      const result = applyCrmRowsToState(state, rows);
      if (result.updated || result.conflicts || result.skipped || options.forceSave) {
        await saveState(key, { state: result.state, allowEmptyPlans: true });
      }
      updated += result.updated;
      skipped += result.skipped;
      conflicts += result.conflicts;
      scopes += 1;
    }
    return {
      ok: true,
      source: 'crm-execution-csv',
      file: crm.file,
      rows: rows.length,
      scopes: scopes,
      updated: updated,
      skipped: skipped,
      conflicts: conflicts,
      refreshedAt: new Date().toISOString()
    };
  }

  let crmAutoRefreshTimer = null;
  let crmAutoRefreshRunning = false;
  function crmRefreshHourOfDay(date) {
    try {
      return Number(new Intl.DateTimeFormat('zh-CN', {
        timeZone: 'Asia/Shanghai',
        hour: '2-digit',
        hour12: false
      }).format(date || new Date()));
    } catch (e) {
      return (date || new Date()).getHours();
    }
  }

  function isCrmRefreshQuietHours(date) {
    const hour = crmRefreshHourOfDay(date);
    return hour >= 1 && hour < 9;
  }

  function startCrmAutoRefresh(intervalMs) {
    const actualInterval = Math.max(10 * 60 * 1000, Number(intervalMs) || 2 * 60 * 60 * 1000);
    if (crmAutoRefreshTimer) return { ok: true, intervalMs: actualInterval, alreadyStarted: true };
    crmAutoRefreshTimer = setInterval(function() {
      if (isCrmRefreshQuietHours(new Date())) {
        logger.info('traffic crm auto refresh skipped in quiet hours', { quietHours: '01:00-09:00 Asia/Shanghai' });
        return;
      }
      if (crmAutoRefreshRunning) return;
      crmAutoRefreshRunning = true;
      refreshCrmExecutionCsvState({ auto: true }).then(function(result) {
        logger.info('traffic crm auto refresh finished', result);
      }).catch(function(err) {
        logger.warn('traffic crm auto refresh failed', err);
      }).finally(function() {
        crmAutoRefreshRunning = false;
      });
    }, actualInterval);
    if (crmAutoRefreshTimer.unref) crmAutoRefreshTimer.unref();
    logger.info('traffic crm auto refresh scheduled', { intervalMs: actualInterval });
    return { ok: true, intervalMs: actualInterval };
  }

  return {
    _startCrmAutoRefresh: startCrmAutoRefresh,

    '/api/traffic-plan/state': function(body, cb) {
      withReady(function() {
        const key = trafficScopeKey(body);
        const legacyKey = userKey(body);
        if (body._method === 'GET' || body.action === 'read') {
          Promise.all([
            readState(key),
            legacyKey !== key ? readState(legacyKey) : Promise.resolve({ projects: [], plans: [], importedVideos: [], accountLibrary: [], applyRequests: [], updatedAt: 0, scopeKey: legacyKey })
          ]).then(function(results) {
            cb(mergeTrafficStates(results[0], results[1]));
          }).catch(function(err) {
            cb({ ok: false, error: err.message || String(err) });
          });
          return;
        }
        if (body._method === 'POST' || body._method === 'PUT' || body._method === 'PATCH') {
          saveState(key, body.state ? body : { state: stateFromBody(body) }).then(cb).catch(function(err) {
            cb({ ok: false, error: err.message || String(err) });
          });
          return;
        }
        cb({ ok: false, error: 'Unsupported method' });
      }, cb);
    },

    '/api/traffic-plan/reset': function(body, cb) {
      withReady(function() {
        saveState(trafficScopeKey(body), { state: EMPTY_STATE, allowEmptyPlans: true, replaceState: true }).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/delete-project': function(body, cb) {
      withReady(function() {
        deleteProjectState(trafficScopeKey(body), body.projectId || body.projectKey || body.projectName).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/group-tasks': function(body, cb) {
      withReady(function() {
        const groupName = text(body.groupName || body.group || body._auth && body._auth.group_name);
        if (!groupName) {
          cb({ ok: true, scopeKey: '', legacyKey: userKey(body), plans: [] });
          return;
        }
        readGroupTasks(groupName, userKey(body)).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/maintenance-sources': function(body, cb) {
      withReady(function() {
        const groupName = text(body.groupName || body.group || body._auth && body._auth.group_name);
        if (!groupName) {
          cb({ ok: true, groupName: '', count: 0, plans: [] });
          return;
        }
        readMaintenanceSources(groupName).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/maintenance-state': function(body, cb) {
      withReady(function() {
        const key = maintenanceScopeKey(body);
        const legacyKey = userKey(body);
        if (body._method === 'GET' || body.action === 'read') {
          Promise.all([
            readMaintenanceState(key),
            legacyKey !== key ? readMaintenanceState(legacyKey) : Promise.resolve({ records: [], groupConfigs: [] })
          ]).then(function(results) {
            const primary = results[0] || {};
            const legacy = results[1] || {};
            const recordMap = new Map();
            (legacy.records || []).concat(primary.records || []).forEach(function(record) {
              if (!record) return;
              const id = text(record.id) || [record.groupName, record.targetName, record.accountName, record.phaseName].map(text).join('|');
              if (id) recordMap.set(id, Object.assign({}, recordMap.get(id) || {}, record));
            });
            const configMap = new Map();
            (legacy.groupConfigs || []).concat(primary.groupConfigs || []).forEach(function(config) {
              if (!config) return;
              const groupName = text(config.groupName || config.group) || '未分�?;
              configMap.set(groupName, Object.assign({}, configMap.get(groupName) || {}, config, { groupName: groupName }));
            });
            cb({
              ok: true,
              scopeKey: key,
              legacyKey: legacyKey,
              records: Array.from(recordMap.values()),
              groupConfigs: Array.from(configMap.values()),
              updatedAt: Math.max(primary.updatedAt || 0, legacy.updatedAt || 0)
            });
          }).catch(function(err) {
            cb({ ok: false, error: err.message || String(err) });
          });
          return;
        }
        saveMaintenanceState(key, body.state || body).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/bilibili-stats': function(body, cb) {
      const url = String(body.url || body.bvid || '').trim();
      if (!url) {
        cb({ ok: false, error: '请先填写 B站视频链接或 BV �? });
        return;
      }
      runPython('bilibili_stats.py', 'stats', { url: url }, 75).then(function(result) {
        if (result && result.ok) {
          cb(Object.assign({
            source_method: 'B站视频链�?BV -> bili video <BV> --json；评论等缺字段时�?api.bilibili.com/x/web-interface/view；回填播放、弹幕、评论、点赞、收藏、投币、分�?
          }, result));
          return;
        }
        cb({
          ok: false,
          error: result && (result.error || result.message) || ''
        });
      });
    },

    '/api/traffic-plan/douyin-stats': function(body, cb) {
      fetchDouyinVideoStats(body || {}).then(cb).catch(function(err) {
        cb({ ok: false, error: err.message || String(err) });
      });
    },

    '/api/traffic-plan/crm-execution-csv': function(body, cb) {
      try {
        const result = readLatestCrmCsv();
        if (!result.ok) {
          cb(result);
          return;
        }
        const limit = Math.max(1, Math.min(5000, Number(body && body.limit) || 2000));
        cb(Object.assign({}, result, {
          rows: result.rows.slice(0, limit)
        }));
      } catch (err) {
        cb({ ok: false, error: err.message || String(err) });
      }
    },

    '/api/traffic-plan/crm-refresh-now': function(body, cb) {
      withReady(function() {
        refreshCrmExecutionCsvState({ manual: true, forceSave: Boolean(body && body.forceSave) }).then(cb).catch(function(err) {
          cb({ ok: false, error: err.message || String(err) });
        });
      }, cb);
    },

    '/api/traffic-plan/xingtu-videos': function(body, cb) {
      fetchXingtuVideos(body || {}).then(cb).catch(function(err) {
        cb({ ok: false, error: err.message || String(err) });
      });
    }
  };
};
