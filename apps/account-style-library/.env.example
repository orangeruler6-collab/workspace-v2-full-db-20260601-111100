OPENCLI_BIN=opencli
FFMPEG_BIN=ffmpeg
STYLE_LIBRARY_DIR=./style-library

# Volcengine recording-file recognition 2.0
VOLCENGINE_ASR_API_KEY=
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.auc
VOLCENGINE_ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
VOLCENGINE_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLCENGINE_ASR_AUDIO_FORMAT=mp3
VOLCENGINE_ASR_POLL_INTERVAL_MS=1000
VOLCENGINE_ASR_MAX_POLL_ATTEMPTS=120
VOLCENGINE_ASR_REQUEST_TIMEOUT_MS=30000
VOLCENGINE_ASR_RETRY_COUNT=2
# Douyin batch transcription concurrency. Keep at 1-4; default is 3.
DOUYIN_TRANSCRIBE_CONCURRENCY=3

# Chat endpoint for style extraction and copywriting.
# Default matches this Codex setup. For OpenAI-compatible relays, set CHAT_WIRE_API=chat_completions or auto.
# CHAT_BASE_URL can be a host root such as https://api.example.com/v1, or use the explicit endpoint overrides below.
CHAT_API_KEY=
CHAT_BASE_URL=https://www.fhl.mom
CHAT_RESPONSES_URL=
CHAT_COMPLETIONS_URL=
CHAT_MODEL=gpt-5.5
CHAT_WIRE_API=responses
CHAT_REASONING_EFFORT=xhigh
# Optional: make server-side model requests use the local FlClash proxy.
CHAT_PROXY_URL=http://127.0.0.1:7890
# OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL are also accepted as fallbacks.

# Image endpoint for Bilibili cover generation.
# Defaults to OpenAI Images API with GPT Image 2.
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=2048x1152
IMAGE_QUALITY=medium
IMAGE_FORMAT=jpeg
IMAGE_PROXY_URL=http://127.0.0.1:7890

# Optional: publish generated copy to Feishu Docs.
# By default the app uses your existing opencli lark-cli login as user.
FEISHU_OPENCLI_AS=user
# Optional folder token. Leave empty to create in the app default location.
FEISHU_FOLDER_TOKEN=
