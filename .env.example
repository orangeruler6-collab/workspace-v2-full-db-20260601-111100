# Copy this file to .env on each computer. Do not commit .env.

# Optional. Leave empty to use the bundled tools/douyin-downloader directory.
# DOUYIN_DOWNLOADER_ROOT=/absolute/path/to/douyin-downloader

# Optional. Leave empty to use tools/douyin-downloader/config.local.yml,
# then config.yml, then config.example.yml.
# DOUYIN_DOWNLOADER_CONFIG=/absolute/path/to/config.local.yml

# Optional. Required only when "自动转写" is enabled in 文案工具.
OPENAI_API_KEY=

# 文案工作台原生模块。默认使用仓库内 data/style-library，不会自动迁移或重写用户资产。
STYLE_LIBRARY_DIR=./data/style-library
OPENCLI_BIN=opencli
FFMPEG_BIN=ffmpeg
JOB_MAX_ACTIVE=2
JOB_HISTORY_LIMIT=200
GROSS_MARGIN_MONITOR_REFRESH_CONCURRENCY=3
DOUYIN_TRANSCRIBE_CONCURRENCY=3
DOUYIN_HOTLIST_REFRESH_CONCURRENCY=5

# 火山 ASR：无字幕视频转写兜底。
VOLCENGINE_ASR_API_KEY=
VOLCENGINE_ASR_RESOURCE_ID=volc.seedasr.auc
VOLCENGINE_ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
VOLCENGINE_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLCENGINE_ASR_AUDIO_FORMAT=mp3
VOLCENGINE_ASR_POLL_INTERVAL_MS=1000
VOLCENGINE_ASR_MAX_POLL_ATTEMPTS=120
VOLCENGINE_ASR_REQUEST_TIMEOUT_MS=30000
VOLCENGINE_ASR_RETRY_COUNT=2

# 文案工作台主模型。OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_MODEL 仍兼容。
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_RESPONSES_URL=
CHAT_COMPLETIONS_URL=
CHAT_MODEL=
CHAT_WIRE_API=auto
CHAT_REASONING_EFFORT=none
CHAT_SERVICE_TIER=
CHAT_PROXY_URL=
CHAT_HEALTH_PROBE_TIMEOUT_MS=8000
ENGAGEMENT_MODEL_CONCURRENCY=4

# 文案工作台备用模型。
CHAT_FALLBACK_API_KEY=
CHAT_FALLBACK_BASE_URL=https://www.fhl.mom
CHAT_FALLBACK_RESPONSES_URL=
CHAT_FALLBACK_COMPLETIONS_URL=
CHAT_FALLBACK_MODEL=gpt-5.5
CHAT_FALLBACK_WIRE_API=responses
CHAT_FALLBACK_REASONING_EFFORT=xhigh
CHAT_FALLBACK_SERVICE_TIER=
CHAT_FALLBACK_PROXY_URL=
CHAT_FALLBACK_ENABLED=1

# 封面生成与飞书发布。
IMAGE_API_KEY=
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=2048x1152
IMAGE_QUALITY=medium
IMAGE_FORMAT=jpeg
IMAGE_PROXY_URL=
FEISHU_OPENCLI_AS=user
FEISHU_FOLDER_TOKEN=

# Optional. Used by douyin-downloader if your config reads DOUYIN_COOKIE.
DOUYIN_COOKIE=

# Optional. Leave empty to use the bundled tools/bilibili-cli directory.
# BILIBILI_CLI_ROOT=/absolute/path/to/bilibili-cli

# Optional. Leave empty to use tools/bilibili-cli/.venv/bin/bili, global bili,
# or a Python environment that can import the submodule source.
# BILIBILI_CLI_BIN=/absolute/path/to/bili
# BILIBILI_CLI_PYTHON=/absolute/path/to/python

# Local backend/API keys. Keep real values only in .env.
GATEWAY_TOKEN=
SILICONFLOW_API_KEY=
SF_KEY=
MINIMAX_API_KEY=
GPT_IMAGE2_KEY=
GPT_IMAGE2_PRIMARY_BASE_URL=
GPT_IMAGE2_PRIMARY_KEY=
GPT_IMAGE2_PRIMARY_PROXY=
GPT_IMAGE2_PRIMARY_SSL_VERIFY=
GPT_IMAGE2_FALLBACK_BASE_URL=
GPT_IMAGE2_FALLBACK_KEY=
GPT_IMAGE2_FALLBACK_PROXY=
GPT_IMAGE2_FALLBACK_SSL_VERIFY=

# Admin seed. Used only when auth.db has no active admin.
# If USAGI_ADMIN_PASSWORD is empty, the backend can fall back to GATEWAY_TOKEN.
USAGI_ADMIN_USER=admin
USAGI_ADMIN_PASSWORD=
USAGI_REGISTER_INVITE_CODE=畅玩集团

# Temporary local test switch. Keep false in normal use.
USAGI_AUTH_DISABLED=false
VITE_USAGI_AUTH_DISABLED=false

# Account data collection tuning.
# 4 means run at 04:00. Increase max profiles to cover more accounts per run.
ACCOUNT_DATA_SCHEDULE_HOURS=3
ACCOUNT_DATA_COLLECT_MAX_PROFILES=4
ACCOUNT_DATA_COLLECT_MAX_TARGETS=12
# Comma-separated profile aliases to skip during default scheduled collection.
ACCOUNT_DATA_COLLECT_EXCLUDE_PROFILES=
ACCOUNT_DATA_BATCH_SIZE=2
ACCOUNT_DATA_BATCH_PAUSE_MS=5000
