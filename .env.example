# Copy this file to .env on each computer. Do not commit .env.

# Optional. Leave empty to use the bundled tools/douyin-downloader directory.
# DOUYIN_DOWNLOADER_ROOT=/absolute/path/to/douyin-downloader

# Optional. Leave empty to use tools/douyin-downloader/config.local.yml,
# then config.yml, then config.example.yml.
# DOUYIN_DOWNLOADER_CONFIG=/absolute/path/to/config.local.yml

# Optional. Required only when "自动转写" is enabled in 文案工具.
OPENAI_API_KEY=

# Optional. Used by douyin-downloader if your config reads DOUYIN_COOKIE.
DOUYIN_COOKIE=

# Optional. Leave empty to use the bundled tools/bilibili-cli directory.
# BILIBILI_CLI_ROOT=/absolute/path/to/bilibili-cli

# Optional. Leave empty to use tools/bilibili-cli/.venv/bin/bili, global bili,
# or a Python environment that can import the submodule source.
# BILIBILI_CLI_BIN=/absolute/path/to/bili
# BILIBILI_CLI_PYTHON=/absolute/path/to/python

# Local backend/API keys. Keep real values only in .env.
GATEWAY_TOKEN=
SILICONFLOW_API_KEY=
SF_KEY=
MINIMAX_API_KEY=
GPT_IMAGE2_KEY=
GPT_IMAGE2_PRIMARY_BASE_URL=
GPT_IMAGE2_PRIMARY_KEY=
GPT_IMAGE2_PRIMARY_PROXY=
GPT_IMAGE2_PRIMARY_SSL_VERIFY=
GPT_IMAGE2_FALLBACK_BASE_URL=
GPT_IMAGE2_FALLBACK_KEY=
GPT_IMAGE2_FALLBACK_PROXY=
GPT_IMAGE2_FALLBACK_SSL_VERIFY=

# Admin seed. Used only when auth.db has no active admin.
# If USAGI_ADMIN_PASSWORD is empty, the backend can fall back to GATEWAY_TOKEN.
USAGI_ADMIN_USER=admin
USAGI_ADMIN_PASSWORD=
USAGI_REGISTER_INVITE_CODE=畅玩集团

# Temporary local test switch. Keep false in normal use.
USAGI_AUTH_DISABLED=false
VITE_USAGI_AUTH_DISABLED=false
