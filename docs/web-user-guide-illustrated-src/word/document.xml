<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 wp14"><w:body><w:p><w:pPr><w:pStyle w:val="CoverTitle"/><w:jc w:val="center"/></w:pPr><w:r><w:t xml:space="preserve">乌萨奇工作平台</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="CoverSub"/><w:jc w:val="center"/></w:pPr><w:r><w:t xml:space="preserve">Web 使用教程 · 图文培训版</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:rPr><w:color w:val="6B7280"/></w:rPr><w:t xml:space="preserve">适用：内容选题 / 文案生成 / 排期协作 / 后期发布 / 运营复盘</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="EFF6FF"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="60A5FA"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">主线流程：账号热榜发现机会 → 文案工作流拆解生成 → 排期看板交接 → 后期处理 → 视频发布 → 数据复盘</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">01 快速上手</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblW w:w="10000" w:type="dxa"/><w:tblBorders><w:top w:val="single" w:sz="4" w:color="D1D5DB"/><w:left w:val="single" w:sz="4" w:color="D1D5DB"/><w:bottom w:val="single" w:sz="4" w:color="D1D5DB"/><w:right w:val="single" w:sz="4" w:color="D1D5DB"/><w:insideH w:val="single" w:sz="4" w:color="E5E7EB"/><w:insideV w:val="single" w:sz="4" w:color="E5E7EB"/></w:tblBorders></w:tblPr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="DBEAFE"/></w:tcPr><w:p><w:r><w:rPr><w:b/><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">场景</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="DBEAFE"/></w:tcPr><w:p><w:r><w:rPr><w:b/><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">应该去哪里</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="DBEAFE"/></w:tcPr><w:p><w:r><w:rPr><w:b/><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">一句话说明</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">找爆款/找选题</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">账号热榜 / 每日热点</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">看近期新内容和异常增长，把可做内容送进工作流。</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">视频或 BF 出脚本</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">文案工作流</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">支持视频链接、飞书链接、PDF/Word、商单 BF。</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">单条转写/评论</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">文案工具</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">适合抖音/B 站转写、评论素材、向量搜索。</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">团队任务流转</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">排期看板</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">按人/按周排任务，拖拽交接会全局提醒。</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">素材沉淀</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">素材库</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">上传、分类、AI 打标、加入剪辑篮。</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">发布准备</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">视频发布</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="2500" w:type="dxa"/><w:shd w:fill="FFFFFF"/></w:tcPr><w:p><w:r><w:t xml:space="preserve">上传视频、填标题简介、选择账号平台、生成发布任务。</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="ECFDF5"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="10B981"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="065F46"/></w:rPr><w:t xml:space="preserve">右下角乌萨奇 AI 是全局入口：可以问模块怎么用、让它切到工作流、辅助分析数据，但正式输出仍建议在对应模块内复核。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">02 账号热榜：从账号池发现可做内容</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="1" name="rIdImg1"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg1.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg1" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 1：账号热榜真实页面。左侧为模块导航，中间是榜单，右侧是筛选和账号池。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">账号热榜用于监控抖音、B 站等账号的新内容，把近期表现好、增长异常、值得参考的内容排到前面。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 点击「扫描账号池」拉取账号池最新内容。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 查看榜单前几名，重点看发布时间、平台、点赞/播放/评论等指标。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 用右侧筛选按平台、分区、关键词缩小范围。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 看到合适内容后点击「进工作流」，把链接带入文案工作流。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 同一作品不会重复入库，重复扫描只更新可抓到的数据。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• B 站优先看播放量和点赞，抖音优先看点赞/评论等可返回字段。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 近期发布内容权重更高，老内容会进入历史归档。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="FFFBEB"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="F59E0B"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="92400E"/></w:rPr><w:t xml:space="preserve">不要只看热度数字，要同时判断“是否适合账号定位”和“能否改成我们的表达”。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">03 文案工作流：从素材/BF 到脚本</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="2" name="rIdImg2"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg2.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg2" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 2：文案工作流真实页面。节点按输入、采集、分析、搜索、汇总、创意等步骤连接。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">文案工作流适合复杂脚本生产，支持素材链接、飞书链接、商单 BF、PDF/Word 文件和手动补充要求。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 在输入源选择「素材输入」或「商单 BF」。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 素材输入可填抖音/B 站/飞书链接；商单 BF 可拖拽 PDF/Word 或选择文件。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 按节点顺序运行：输入源、转写/解析、汇总、背景搜索、分析报告、确认创意、生成文案。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 生成文案后人工检查事实、品牌要求、平台风险，再进入排期或发布。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 背景搜索只做补充，不要把未证实传闻当事实。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 客户 BF、转写原文、飞书文档优先级高于外部搜索。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 扫描版 PDF 可能需要 OCR；能用 Word 或文字版 PDF 更稳定。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="EFF6FF"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="60A5FA"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">商单 BF 一定要补充品牌禁忌、卖点、平台、目标账号和交付形式，否则脚本容易泛。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">04 排期看板：任务分配、交接和完成确认</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="3" name="rIdImg3"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg3.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg3" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 3：排期看板真实页面。可以按人或按周查看任务。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">排期看板用于团队协作。文案、后期、运营可以在这里看到任务归属、日期、账号和完成状态。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 选择组别后，默认按人查看每个人任务。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 点击「+ 添加」给成员新增任务。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 文案写完后，把任务卡拖到后期同事名下完成交接。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 被交接人会收到全局弹窗「您收到新的订单」。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">5. 后期完成后点击任务卡上的勾号。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 支持 Ctrl+Z 或「撤销」回退上一步。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 按周视图适合检查账号和日期分布。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• AI 导入适合一次性拆分多条素材代做任务。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="ECFDF5"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="10B981"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="065F46"/></w:rPr><w:t xml:space="preserve">交接尽量用拖拽完成，不要只口头说；这样系统会自动通知对方，也方便后续追踪。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">05 文案工具：轻量转写、评论和检索</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="4" name="rIdImg4"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg4.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg4" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 4：文案工具真实页面。适合单条素材的快速处理。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">文案工具适合轻量任务：抖音转写、B 站转写、评论素材生成、向量搜索。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 粘贴抖音/B 站链接并运行。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 转写完成后可点击「生成文案」或「清洗分段」。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 评论素材区可粘贴脚本，选择数量和账号风格后生成评论。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 向量搜索可输入关键词，检索历史文案和案例。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 复杂多节点脚本建议走文案工作流。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 评论素材生成后建议人工筛掉重复、夸张或不合适表达。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 向量搜索词越具体，命中越好。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="EFF6FF"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="60A5FA"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">文案工具适合快处理，文案工作流适合完整生产，不要混用导致流程断掉。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">06 素材库：统一管理素材和标签</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="5" name="rIdImg5"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg5.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg5" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 5：素材库真实页面。用于上传、筛选、预览和管理文件。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">素材库用于统一管理视频、图片、音频、文档等素材，避免素材散落在聊天记录和本地文件夹里。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 上传素材或新建文件夹。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 给素材补充名称、分类、标签。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 需要时点击 AI 标签辅助识别。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 把要交给后期的素材加入剪辑篮。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 素材入库时就补标签，后续搜索会省很多时间。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 重要素材不要只靠文件名识别。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 删除前确认是否还有排期或发布任务引用。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="ECFDF5"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="10B981"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="065F46"/></w:rPr><w:t xml:space="preserve">素材库的价值在于“可搜索、可复用、可交接”，不是简单网盘。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">07 AI 生图：生成封面和视觉参考</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="6" name="rIdImg6"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg6.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg6" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 6：AI 生图真实页面。支持文生图、图生图和历史记录。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">AI 生图用于生成封面图、视觉参考、角色草图和创意素材。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 选择文生图或图生图。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 输入清晰的画面描述，图生图需要先上传参考图。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 选择模型、比例和数量。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 点击开始生成，完成后下载或复制链接。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 提示词要包含主体、风格、构图、颜色和用途。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 用于对外发布前必须人工复核版权、品牌和视觉风险。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 历史记录可以复用参数，方便继续迭代。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="FFFBEB"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="F59E0B"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="92400E"/></w:rPr><w:t xml:space="preserve">生成图更适合做提案、封面参考和内部素材，正式发布前要过人工审核。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">08 视频发布：整理发布信息并生成任务</w:t></w:r></w:p><w:p><w:pPr><w:jc w:val="center"/></w:pPr><w:r><w:drawing><wp:inline xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" distT="0" distB="0" distL="0" distR="0"><wp:extent cx="9144000" cy="6350000"/><wp:docPr id="7" name="rIdImg7"/><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="0" name="rIdImg7.png"/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rIdImg7" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="9144000" cy="6350000"/></a:xfrm><a:prstGeom prst="roundRect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Caption"/></w:pPr><w:r><w:t xml:space="preserve">图 7：视频发布真实页面。左侧上传视频，中间填写发布信息，右侧选择账号与平台。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">这个模块用来做什么</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">视频发布模块用于把视频、标题、简介、标签、账号和平台整理成发布任务。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">推荐操作步骤</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 上传本地视频，或从素材库导入。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 填写标题、简介、标签和封面信息。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 选择发布账号和平台。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 点击「生成发布任务」。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">使用要点</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 标题建议 10-30 字，优先表达看点。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 简介里可以补充互动引导。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• AI 推荐可先生成一版，但发布前仍要人工检查。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="EFF6FF"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="60A5FA"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="1E3A8A"/></w:rPr><w:t xml:space="preserve">当前模块主要负责生成发布任务；后端接入 OpenCLI 后，可继续打开对应平台发布流程。</w:t></w:r></w:p><w:p><w:r><w:br w:type="page"/></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t xml:space="preserve">09 常见问题与处理方式</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">飞书链接读不了</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 确认当前账号有文档权限。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 确认飞书授权未过期。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 确认链接是正文文档，不是无权限分享页。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">PDF 解析失败</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 优先使用 Word 或可复制文字版 PDF。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 扫描版 PDF 需要 OCR；如果失败，先把正文粘贴到补充文本。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">热榜字段缺失</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 不同平台可抓取数据不同，系统只展示稳定返回的字段。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">文案生成卡住</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 先重新运行当前节点，不要直接重置全流程。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 检查输入源、链接、BF 文件是否可读。</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Callout"/><w:shd w:fill="FFFBEB"/><w:pBdr><w:left w:val="single" w:sz="18" w:space="8" w:color="F59E0B"/></w:pBdr></w:pPr><w:r><w:rPr><w:color w:val="92400E"/></w:rPr><w:t xml:space="preserve">如果页面看起来异常，先刷新当前页；如果是接口错误，再联系管理员查看后端日志。</w:t></w:r></w:p><w:sectPr><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="720" w:right="720" w:bottom="720" w:left="720" w:header="720" w:footer="720" w:gutter="0"/></w:sectPr></w:body></w:document>